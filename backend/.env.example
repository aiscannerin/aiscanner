# ── Flask ──────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=CHANGE_ME_use_a_long_random_secret_key_min_32_chars

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/stophunterpro

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Celery ─────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_use_a_different_long_random_key_min_32_chars
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# ── Razorpay ───────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXX

# ── Brevo transactional email ──────────────────────────────────────────────────
# Get your API key from https://app.brevo.com/settings/keys/api
# BREVO_ENABLED=false  → OTP printed to console only (development default)
# BREVO_ENABLED=true   → OTP sent via Brevo (required in production)
BREVO_API_KEY=xkeysib-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Stop Hunter Pro
BREVO_ENABLED=false

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your_app_password
MAIL_DEFAULT_SENDER=noreply@stophunterpro.com

# ── Rate Limiting — Flask-Limiter 3.x uses RATELIMIT_STORAGE_URI (not URL) ────
RATELIMIT_STORAGE_URI=redis://localhost:6379/2

# ── OTP ────────────────────────────────────────────────────────────────────────
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Dashboard URL (used in email alert links) ──────────────────────────────────
# Set to the frontend URL so email alerts can link back to the dashboard.
DASHBOARD_URL=http://localhost:3000

# ── Max Pain snapshot retention ────────────────────────────────────────────────
# Snapshots older than this many days are deleted by the daily Celery cleanup task.
MAX_PAIN_RETENTION_DAYS=90
