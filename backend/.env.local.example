# ============================================================
#  backend/.env.local.example
#  Template for LOCAL DEVELOPMENT machines (Mum PC, dev laptop, etc.)
#
#  Usage:
#    Copy to backend/.env and fill in your local values.
#    Do NOT commit backend/.env — it is in .gitignore.
# ============================================================

# ── Flask ──────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=dev_secret_key_change_later_1234567890

# ── Backend port ───────────────────────────────────────────────────────────────
PORT=3010

# ── Database ───────────────────────────────────────────────────────────────────
# Local PostgreSQL — password is whatever you set during install
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stophunterpro

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Celery ─────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=dev_jwt_secret_key_change_later_1234567890
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# ── Razorpay (use test keys locally) ──────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=dev_webhook_secret

# ── Brevo transactional email ──────────────────────────────────────────────────
# Set BREVO_ENABLED=false locally → OTP is printed to console only (no emails sent)
BREVO_API_KEY=xkeysib-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Stop Hunter Pro
BREVO_ENABLED=false

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your_app_password
MAIL_DEFAULT_SENDER=noreply@stophunterpro.com

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATELIMIT_STORAGE_URI=redis://localhost:6379/2

# ── OTP ────────────────────────────────────────────────────────────────────────
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Dashboard URL ──────────────────────────────────────────────────────────────
DASHBOARD_URL=http://localhost:3000

# ── Max Pain snapshot retention ────────────────────────────────────────────────
MAX_PAIN_RETENTION_DAYS=90
