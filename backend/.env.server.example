# ============================================================
#  backend/.env.server.example
#  Template for the PRODUCTION SERVER (Windows Server 2022,
#  D:\stop_hunt_pro\...\aiscanner running through Cloudflare Tunnel)
#
#  Usage:
#    On the server: copy to backend/.env and fill in REAL values.
#    Do NOT commit backend/.env — it is in .gitignore.
#    Do NOT use dev/placeholder keys on the server.
# ============================================================

# ── Flask ──────────────────────────────────────────────────────────────────────
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=CHANGE_ME_use_a_long_random_secret_key_min_32_chars

# ── Backend port ───────────────────────────────────────────────────────────────
PORT=3010

# ── Database ───────────────────────────────────────────────────────────────────
# Use the actual server PostgreSQL password (URL-encode special chars: @ = %40)
DATABASE_URL=postgresql://postgres:YOUR_REAL_DB_PASSWORD@localhost:5432/stophunterpro

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Celery ─────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_use_a_different_long_random_key_min_32_chars
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# ── Razorpay ───────────────────────────────────────────────────────────────────
# Use LIVE keys on the server (rzp_live_...) when going live
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXX

# ── Brevo transactional email ──────────────────────────────────────────────────
# BREVO_ENABLED=true is required on the server so OTPs are actually emailed
BREVO_API_KEY=xkeysib-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
BREVO_SENDER_EMAIL=aiscannerin@gmail.com
BREVO_SENDER_NAME=Stop Hunter Pro
BREVO_ENABLED=true

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your_app_password
MAIL_DEFAULT_SENDER=noreply@stophunterpro.com

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATELIMIT_STORAGE_URI=redis://localhost:6379/2

# ── OTP ────────────────────────────────────────────────────────────────────────
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5

# ── CORS ───────────────────────────────────────────────────────────────────────
# Include BOTH localhost (for direct server testing) and the public domain
CORS_ORIGINS=http://localhost:3000,https://aiscanner.in

# ── Dashboard URL ──────────────────────────────────────────────────────────────
# Must match the public-facing URL so email alert links work
DASHBOARD_URL=https://aiscanner.in

# ── Max Pain snapshot retention ────────────────────────────────────────────────
MAX_PAIN_RETENTION_DAYS=90
