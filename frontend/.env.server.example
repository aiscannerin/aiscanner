# ============================================================
#  frontend/.env.server.example
#  Template for the PRODUCTION SERVER (aiscanner.in via Cloudflare Tunnel).
#
#  Usage:
#    On the server: copy to frontend/.env and adjust if needed.
#    Do NOT commit frontend/.env — it is in .gitignore.
# ============================================================

# API base URL — use /api (same-origin through Vite proxy or reverse proxy).
# Cloudflare Tunnel routes all traffic through the same origin,
# so /api works correctly whether accessed via localhost, LAN, or aiscanner.in.
VITE_API_URL=/api
