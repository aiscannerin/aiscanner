# ============================================================
#  frontend/.env.local.example
#  Template for LOCAL DEVELOPMENT machines.
#
#  Usage:
#    Copy to frontend/.env and adjust if needed.
#    Do NOT commit frontend/.env — it is in .gitignore.
# ============================================================

# API base URL — always use /api in development so Vite's proxy handles it.
# The proxy in vite.config.js forwards /api → http://localhost:3010
# DO NOT set this to http://localhost:3010/api — that bypasses the proxy.
VITE_API_URL=/api
